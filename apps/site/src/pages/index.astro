---
import "@fontsource-variable/bricolage-grotesque";
import "@fontsource-variable/outfit";
import "../styles/global.css";

const GITHUB = "https://github.com/Reality-Shifting-Tech/mailpelican";

const audiences = [
  {
    tag: "Self-hosters",
    title: "Own your stack",
    points: [
      "One Docker image: API, worker, console, rspamd",
      "PostgreSQL + Redis, your domains, your data",
      "AGPL-3.0 — no per-subscriber pricing, ever",
    ],
  },
  {
    tag: "Agent operators",
    title: "Let agents drive",
    points: [
      "MCP server exposes the whole /v1 API",
      "Agents draft, lint, and preview campaigns",
      "Confirmed sends stay behind a human-held token",
    ],
  },
  {
    tag: "Deliverability nerds",
    title: "See what filters see",
    points: [
      "Preflight: SPF, DMARC, MX, rDNS, blocklists",
      "rspamd scores every campaign before it ships",
      "DMARC rua ingestion and IP warmup ramps",
    ],
  },
];

const features = [
  {
    title: "Safe-send pipeline",
    body: "Every campaign goes lint → preview → audience snapshot → single-use confirmation token → send. Nothing ships by accident, and API keys carry send limits and approval thresholds.",
    featured: true,
  },
  {
    title: "Consent & compliance built in",
    body: "Double opt-in with single-use confirmation tokens, workspace-global suppression, per-dispatch consent rechecks, CAN-SPAM footers, and RFC 8058 one-click unsubscribe.",
  },
  {
    title: "Relay-agnostic sending",
    body: "Send through AWS SES v2, Resend, or any SMTP server behind one RelayProvider contract. Webhook feedback is verified, normalized, and auto-pauses on bounce/complaint spikes.",
  },
  {
    title: "Open & click tracking",
    body: "Pixel and redirect tracking with per-contact opt-out, unique open/click stats per campaign, and no leakage of message existence to scanners.",
  },
  {
    title: "React Email templates",
    body: "Templates are typed design documents compiled to client-safe HTML at authoring time — compiler-checked, merge-tag aware, plain-text alternative included.",
  },
];

const deliverability = [
  {
    title: "Deliverability preflight",
    body: "One check covers SPF, DMARC, MX, forward-confirmed reverse DNS, and the Spamhaus blocklist — the five things that actually decide whether you inbox, verified live before you send.",
  },
  {
    title: "Spam scoring with rspamd",
    body: "The same open-source filter ISPs run, shipped in the box. Campaign previews show the composite score and every rule your content trips — no black-box “spam score: bad”.",
  },
  {
    title: "DMARC report inbox",
    body: "Gmail, Yahoo, and Microsoft send you free daily authentication telemetry as DMARC rua reports. Mail Pelican ingests and aggregates them: pass rates, failing sources, and spoofing attempts per domain.",
  },
  {
    title: "IP warmup ramps",
    body: "A fresh IP sending full volume on day one is how domains burn. Relays can run a daily doubling warmup ramp enforced by the send pipeline, so reputation grows on schedule.",
  },
];

const faq = [
  {
    q: "Is Mail Pelican really free?",
    a: "The software is AGPL-3.0 and free forever. You pay for your own infrastructure — a VPS, PostgreSQL, Redis — and whatever your relay charges for delivery (SES is $0.10 per 1,000 emails). There is no per-subscriber fee and no feature gate.",
  },
  {
    q: "How is this different from listmonk or Mautic?",
    a: "Two things: deliverability instrumentation (preflight checks, rspamd scoring, DMARC ingestion, warmup ramps — nobody else in the category ships these) and agent-native operation through a first-class MCP server. It is also younger, with a smaller feature set in areas like automation sequences.",
  },
  {
    q: "Do I need to run my own SMTP server?",
    a: "No. Most operators send through AWS SES, Resend, or an existing SMTP account. Self-hosting Mail Pelican means owning your data and control plane; the sending IPs can still be rented from a provider with established reputation — which is the setup we recommend.",
  },
  {
    q: "Will my mail land in spam?",
    a: "Not if you do the boring parts — and we make them checkable. Run the preflight, publish the DNS records it verifies, warm up new IPs on the built-in ramp, and watch DMARC reports for failures. What we will not do is pretend a $5 VPS inboxes on day one.",
  },
  {
    q: "Can an AI agent send campaigns by itself?",
    a: "An agent can do everything up to the point of no return: build audiences, author drafts, lint, preview, and prepare. The confirmed send requires a single-use token from prepare plus an explicit confirmation — a human, or an automation you deliberately hand that token to.",
  },
];

const quickstart = `$ docker compose up -d postgres redis rspamd
$ pnpm --filter @mailpelican/db migrate
$ pnpm --filter @mailpelican/api bootstrap "Workspace" "Org" "1 Main St"
owner api key (store it now): dk_…
$ pnpm dev   # api :3000 · web :5173 · worker`;

const mcpConfig = `{
  "mcpServers": {
    "mailpelican": {
      "command": "node",
      "args": ["apps/mcp/dist/index.js"],
      "env": {
        "MAILPELICAN_API_URL": "http://localhost:3000",
        "MAILPELICAN_API_KEY": "dk_..."
      }
    }
  }
}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mail Pelican — open-source, agent-native email marketing</title>
    <meta
      name="description"
      content="Mail Pelican is the AGPL-3.0, self-hostable, agent-native email marketing platform. Safe sends, consent built in, deliverability instruments, SES/Resend/SMTP, MCP for AI agents."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Mail Pelican — email marketing your agents can operate" />
    <meta
      property="og:description"
      content="Self-hostable, agent-native email marketing with real deliverability instruments. AGPL-3.0."
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%230e5f56'/%3E%3Ctext x='16' y='22' font-family='Helvetica' font-weight='bold' font-size='16' fill='white' text-anchor='middle'%3EP%3C/text%3E%3C/svg%3E"
    />
  </head>
  <body>
    <nav>
      <div class="wrap nav-inner">
        <a class="brand" href="/">
          <span class="brand-mark">P</span>
          Mail Pelican
        </a>
        <div class="links">
          <a href="#features">Features</a>
          <a href="#deliverability">Deliverability</a>
          <a href="#agents">Agents</a>
          <a href="#faq">FAQ</a>
          <a class="btn primary" href={GITHUB}>GitHub</a>
        </div>
      </div>
    </nav>

    <div class="wrap">
      <header class="hero">
        <div>
          <span class="kicker">Open source · AGPL-3.0 · Self-hostable</span>
          <h1>Email marketing your agents can operate.</h1>
          <p class="lede">
            Mail Pelican is the open-source Mailchimp alternative built for self-hosters and for AI
            agents as first-class operators. Safe sends, consent and compliance by default, and
            deliverability instruments nobody else in the category ships.
          </p>
          <div class="cta">
            <a class="btn primary" href={GITHUB}>Star on GitHub</a>
            <a class="btn ghost" href="#self-host">Self-host in 5 minutes</a>
            <a class="btn text" href="#deliverability">Will I inbox? →</a>
          </div>
          <div class="hero-proof">
            <div class="stat">
              <div class="value">3</div>
              <div class="label">Relay drivers</div>
            </div>
            <div class="stat">
              <div class="value">190+</div>
              <div class="label">Tests, zero infra</div>
            </div>
            <div class="stat">
              <div class="value">AGPL</div>
              <div class="label">Forever</div>
            </div>
          </div>
        </div>
        <div class="terminal reveal">
          <span class="dim"># first safe send, from zero</span><br />
          {
            quickstart.split("\n").map((line) => (
              <>
                {line}
                <br />
              </>
            ))
          }
        </div>
      </header>

      <div class="strip">
        {
          ["AWS SES v2", "Resend", "SMTP", "rspamd", "PostgreSQL 16", "Redis", "BullMQ", "MCP"].map(
            (name) => <span class="chip">{name}</span>,
          )
        }
      </div>

      <section class="audience" id="who">
        <div class="section-head">
          <h2>Who Mail Pelican is for</h2>
          <p class="sub">Three kinds of operators, one control plane.</p>
        </div>
        <div class="cards">
          {
            audiences.map((a) => (
              <div class="card">
                <div class="card-tag">{a.tag}</div>
                <h3>{a.title}</h3>
                <ul>
                  {a.points.map((point) => (
                    <li>{point}</li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </section>

      <section id="features">
        <div class="section-head">
          <h2>Built for safety first</h2>
          <p class="sub">
            The unglamorous parts of email — consent, suppression, idempotency, bounce handling —
            are the parts Mail Pelican refuses to compromise on.
          </p>
        </div>
        <div class="cards">
          {
            features.map((f) => (
              <div class={f.featured ? "card featured" : "card"}>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section id="deliverability">
        <div class="section-head">
          <h2>"Just add DNS records" is not a deliverability strategy</h2>
          <p class="sub">
            Every self-hosted mail tool promises inbox placement. The honest truth: SPF/DKIM/DMARC
            are necessary, not sufficient — IP reputation is the gate. Mail Pelican gives you the
            instruments instead of the fairy tale.
          </p>
        </div>
        <div class="cards two">
          {
            deliverability.map((f) => (
              <div class="card">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            ))
          }
        </div>
      </section>

      <section id="agents">
        <div class="section-head">
          <h2>Agent-native by design</h2>
          <p class="sub">
            Every operation the console exposes is reachable through the <code>/v1</code> API — and through
            the bundled MCP server, your agents can build audiences, author drafts, and review previews
            while sends stay human-confirmed.
          </p>
        </div>
        <div class="terminal reveal">
          <span class="dim"># ~/.config/your-agent/mcp.json</span><br />
          {
            mcpConfig.split("\n").map((line) => (
              <>
                {line}
                <br />
              </>
            ))
          }
        </div>
      </section>

      <section id="self-host">
        <div class="section-head">
          <h2>Your infrastructure, your rules</h2>
          <p class="sub">
            One all-in-one container carries the API, the send worker, and the control console.
            Bring PostgreSQL 16 and Redis; keep your domains, your suppression lists, and your
            subscriber data on hardware you own.
          </p>
        </div>
        <div class="cta">
          <a class="btn primary" href={`${GITHUB}#quickstart`}>Read the quickstart</a>
        </div>
      </section>

      <section id="faq">
        <div class="section-head">
          <h2>Frequently asked questions</h2>
        </div>
        {
          faq.map((item) => (
            <div class="faq-item">
              <h3>{item.q}</h3>
              <p>{item.a}</p>
            </div>
          ))
        }
      </section>

      <div class="final">
        <div>
          <h2>Send your first safe campaign this week.</h2>
          <p>Star the repo, spin up the stack, and see what your spam filter sees.</p>
        </div>
        <a class="btn primary" href={GITHUB}>Get started on GitHub</a>
      </div>

      <footer>
        <span>
          AGPL-3.0 · A <a href="https://realityshiftingtech.com">Reality Shifting Tech</a> project
        </span>
        <span>
          <a href={GITHUB}>GitHub</a> · <a href={`${GITHUB}/blob/main/SECURITY.md`}>Security</a>
        </span>
      </footer>
    </div>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15 },
      );
      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
